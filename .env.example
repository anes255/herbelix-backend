# Database (Neon PostgreSQL) — get this from your Neon dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Server
PORT=4000
NODE_ENV=development

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# Default admin (used only by the one-time seed script)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# CORS — comma separated allowed origins for the client.
# Entries may use a "*" wildcard for subdomains, e.g. https://*.vercel.app
CLIENT_ORIGIN="http://localhost:5173,https://www.herblixs.org,https://herblixs.org,https://*.vercel.app"
